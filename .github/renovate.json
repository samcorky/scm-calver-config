{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:semverAllWeekly",
    ":automergePr",
    ":dependencyDashboard",
    ":automergeStableNonMajor",
    ":automergeRequireAllStatusChecks",
    ":configMigration",
    ":enableVulnerabilityAlertsWithLabel(security)",
    ":label(dependencies)",
    ":updateNotScheduled",
    ":maintainLockFilesWeekly",
    ":rebaseStalePrs",
    ":automergeMinor",
    ":combinePatchMinorReleases",
    "security:openssf-scorecard"
  ],
  "enabledManagers": ["pep621", "github-actions"],
  "prHourlyLimit": 5,
  "prConcurrentLimit": 5,
  "schedule": ["before 9am on Monday"],
  "timezone": "Europe/London",
  "pruneStaleBranches": true,
  "packageRules": [
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["project.dependencies", "build-system.requires"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "runtime dependencies",
      "commitMessageAction": "Update",
      "commitMessageTopic": "runtime deps",
      "commitMessageExtra": "{{depName}} to {{newVersion}}",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependency-groups"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dev dependencies",
      "commitMessageAction": "Update",
      "commitMessageTopic": "dev deps",
      "commitMessageExtra": "{{depName}} to {{newVersion}}",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "GitHub Actions",
      "commitMessageAction": "Update",
      "commitMessageTopic": "GitHub Actions",
      "commitMessageExtra": "{{depName}} to {{newVersion}}",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchUpdateTypes": ["lockFileMaintenance"],
      "groupName": "lockfile maintenance",
      "commitMessageAction": "Update",
      "commitMessageTopic": "lockfiles",
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
