{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:semverAllWeekly",
    ":automergePr",
    ":dependencyDashboard",
    ":automergeStableNonMajor",
    ":automergeRequireAllStatusChecks",
    ":configMigration",
    ":enableVulnerabilityAlertsWithLabel(security)",
    ":label(dependencies)",
    ":updateNotScheduled",
    ":maintainLockFilesWeekly",
    ":rebaseStalePrs",
    ":automergeMinor",
    ":combinePatchMinorReleases",
    "security:openssf-scorecard"
  ],
  "enabledManagers": ["pep621", "pre-commit", "github-actions"],
  "pre-commit": {
    "enabled": true
  },
  "prHourlyLimit": 5,
  "prConcurrentLimit": 5,
  "schedule": ["before 9am on Monday"],
  "timezone": "Europe/London",
  "pruneStaleBranches": true,
  "packageRules": [
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["project.dependencies", "build-system.requires"],
      "rangeStrategy": "widen"
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependency-groups"],
      "rangeStrategy": "widen"
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["project.dependencies", "build-system.requires"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "runtime dependencies",
      "groupSlug": "weekly-runtime",
      "commitMessageAction": "chore",
      "commitMessageTopic": "runtime deps",
      "commitMessageExtra": "Update {{depName}} to {{newVersion}}"
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependency-groups"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dev dependencies",
      "groupSlug": "weekly-dev",
      "commitMessageAction": "chore",
      "commitMessageTopic": "dev deps",
      "commitMessageExtra": "Update {{depName}} to {{newVersion}}"
    },
    {
      "matchManagers": ["pre-commit"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "pre-commit hooks",
      "groupSlug": "weekly-precommit",
      "commitMessageAction": "chore",
      "commitMessageTopic": "pre-commit hooks",
      "commitMessageExtra": "Update {{depName}} to {{newVersion}}"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "GitHub Actions",
      "groupSlug": "weekly-gh-actions",
      "commitMessageAction": "chore",
      "commitMessageTopic": "GitHub Actions",
      "commitMessageExtra": "Update {{depName}} to {{newVersion}}"
    },
    {
      "matchUpdateTypes": ["lockFileMaintenance"],
      "groupName": "lockfile maintenance",
      "groupSlug": "weekly-lockfiles",
      "commitMessageAction": "chore",
      "commitMessageTopic": "lockfiles",
      "commitMessageExtra": "Regenerate lock files",
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}